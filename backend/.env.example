# Configuración de Base de Datos
# Copia este archivo a .env y completa con tus valores reales

# Configuración Local (Desarrollo)
MYSQLHOST=localhost
MYSQLUSER=root
MYSQLPASSWORD=
MYSQLDATABASE=erp_pollo_fiesta
MYSQLPORT=3306

# Railway MySQL (Producción) - Descomenta para usar
# MYSQLHOST=your-host.proxy.rlwy.net
# MYSQLUSER=root
# MYSQLPASSWORD=your-password-here
# MYSQLDATABASE=railway
# MYSQLPORT=12345

# O usa la URL completa
# MYSQL_URL=mysql://user:password@host:port/database

# Servidor
PORT=3001
NODE_ENV=development

# JWT
JWT_SECRET=fia-pollo-fiesta-secret-2025
JWT_EXPIRATION=24h

# CORS
CORS_ORIGIN=*
